# EmailJS Configuration
# Get these values from https://dashboard.emailjs.com/

# Your EmailJS Public Key (from Account > API Keys)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your Email Service ID (from Email Services)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxxxxxx

# Your Email Template ID (from Email Templates)
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxxxxxx

# Your email address where messages will be sent
VITE_RECEIVER_EMAIL=skmothi19@gmail.com
